# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Serper (web search) ──────────────────────────────────────────────────────
SERPER_API_KEY=...

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Matches the docker-compose.yml defaults — change for production
DATABASE_URL=postgresql://sourcingagent:password@localhost:5432/sourcingagent

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Max requests per minute on search/generate endpoints
RATE_LIMIT_PER_MINUTE=10
